{
  "name": "rootlens",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:graphs": "python3 scripts/build-graphs.py",
    "build:evidence": "python3 scripts/build-evidence.py --tep-max-cases 10",
    "build:runtime": "node scripts/build-unified-graphs.mjs",
    "dev": "npm run build:graphs && npm run build:evidence && npm run build:runtime && vite",
    "build": "npm run build:graphs && npm run build:evidence && npm run build:runtime && vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@arco-design/web-vue": "^2.57.0",
    "@vueuse/core": "^14.3.0",
    "echarts": "^6.0.0",
    "vue": "^3.5.32",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "csv-parse": "^6.2.0",
    "jsdom": "^27.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.0.8",
    "vue-tsc": "^3.2.7"
  }
}
